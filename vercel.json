{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "env": {
    "NEON_DATABASE_URL": "@NEON_DATABASE_URL",
    "SMTP_HOST": "@SMTP_HOST",
    "SMTP_PORT": "@SMTP_PORT",
    "SMTP_USER": "@SMTP_USER",
    "SMTP_PASS": "@SMTP_PASS",
    "SMTP_FROM": "@SMTP_FROM",
    "ORDER_NOTIFICATION_EMAIL": "@ORDER_NOTIFICATION_EMAIL",
    "ADMIN_TOKEN": "@ADMIN_TOKEN"
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    }
  ]
}
